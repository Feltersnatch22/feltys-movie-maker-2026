{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for main and preview windows",
  "windows": ["main", "preview-popout"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:webview:allow-create-webview-window",
    "core:window:allow-create",
    "core:window:allow-set-focus",
    "core:window:allow-set-position",
    "core:window:allow-set-size",
    "core:window:allow-outer-position",
    "core:window:allow-outer-size",
    "core:window:allow-current-monitor",
    "core:window:allow-available-monitors",
    "core:window:allow-primary-monitor",
    "core:window:allow-monitor-from-point",
    "core:window:allow-set-fullscreen",
    "core:window:allow-is-fullscreen",
    "core:window:allow-close",
    "core:window:allow-show",
    "core:window:allow-hide",
    "opener:default",
    "dialog:default",
    "fs:default",
    "shell:allow-open",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "binaries/ffmpeg", "sidecar": true, "args": true },
        { "name": "binaries/ffprobe", "sidecar": true, "args": true }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "binaries/ffmpeg", "sidecar": true, "args": true },
        { "name": "binaries/ffprobe", "sidecar": true, "args": true }
      ]
    },
    {
      "identifier": "fs:allow-read-file",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [{ "path": "**" }]
    }
  ]
}
