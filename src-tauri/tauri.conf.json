{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Felty's Movie Maker 2026",
  "version": "0.1.0",
  "identifier": "com.mjk.modern-movie-maker",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Felty's Movie Maker 2026",
        "width": 1800,
        "height": 1080,
        "minWidth": 1280,
        "minHeight": 800,
        "maximized": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "app", "dmg", "deb", "rpm", "appimage"],
    "externalBin": [
      "binaries/ffmpeg",
      "binaries/ffprobe"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
